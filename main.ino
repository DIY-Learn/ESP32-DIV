  tft.fillScreen(BG);
  int logoX = (240 - 200) / 2;   // center X = 60
  int logoY = (320 - 200) / 2;   // center Y = 100
  tft.pushImage(logoX, logoY, 200, 200, boot_logo);
  delay(2000);                    // show for 2 seconds
  tft.fillScreen(BG);             // clear before menu
}


// -------- LOOP --------
void loop() {
  int old = selected;
  if (readButtonOnce(BTN_RIGHT)) { selected++; if (selected >= TOTAL) selected = 0; updateSelection(old, selected); delay(200); }
  else if (readButtonOnce(BTN_LEFT)) { selected--; if (selected < 0) selected = TOTAL - 1; updateSelection(old, selected); delay(200); }
  else if (readButtonOnce(BTN_DOWN)) { selected += 2; if (selected >= TOTAL) selected %= 2; updateSelection(old, selected); delay(200); }
  else if (readButtonOnce(BTN_UP)) { selected -= 2; if (selected < 0) selected += TOTAL; updateSelection(old, selected); delay(200); }
  else if (readButtonOnce(BTN_OK)) {
    switch (selected) {
      case 0:
        drawWiFiMenu();
        while (true) {
          if (handleWiFiMenu()) break;
          delay(50);
        }
        drawUI();
        break;
      case 1: attackIR(); break;
      case 2:
        drawBluetoothMenu();
        while (true) {
          if (handleBluetoothMenu()) break;
          delay(50);
        }
        drawUI();
        break;
      case 3: attackTools(); break;
      case 4: attack2_4GHz(); break;
      case 5: attackSettings(); break;
      case 6: attackSubGHz(); break;
      case 7: attackAbout(); break;
    }
    delay(200);
  }
}
// -------- ICON WITH ROUNDED CORNERS (unchanged) --------
void drawRoundedIcon(int x, int y, int w, int h, const uint16_t* icon, int radius) {
  uint16_t buffer[w * h];
  memcpy_P(buffer, icon, w * h * sizeof(uint16_t));
  for (int px = 0; px < w; px++) {
    for (int py = 0; py < h; py++) {
      bool inside = true;
      int dx = px, dy = py;
      if (px < radius && py < radius) {
        if ((radius - px) * (radius - px) + (radius - py) * (radius - py) > radius * radius)
          inside = false;
      }
      else if (px >= w - radius && py < radius) {
        dx = w - 1 - px;
        if ((radius - dx) * (radius - dx) + (radius - py) * (radius - py) > radius * radius)
          inside = false;
      }
      else if (px < radius && py >= h - radius) {
        dy = h - 1 - py;
        if ((radius - px) * (radius - px) + (radius - dy) * (radius - dy) > radius * radius)
          inside = false;
      }
      else if (px >= w - radius && py >= h - radius) {
        dx = w - 1 - px;
        dy = h - 1 - py;
        if ((radius - dx) * (radius - dx) + (radius - dy) * (radius - dy) > radius * radius)
          inside = false;
      }
      if (inside) {
        uint16_t color = buffer[py * w + px];
        tft.drawPixel(x + px, y + py, color);
      }
    }
  }
}

void drawTile(int i, bool active) {
  int col = i % 2;
  int row = i / 2;
  int x = START_X + col * (TILE_W + GAP_X);
  int y = START_Y + row * (TILE_H + GAP_Y);
  uint16_t borderColor = active ? SELECT : BORDER;
  uint16_t textColor   = active ? SELECT : TEXT;
  tft.fillRoundRect(x, y, TILE_W, TILE_H, 10, TILE);
  tft.drawRoundRect(x, y, TILE_W, TILE_H, 10, borderColor);
  int iconX = x + (TILE_W - 32) / 2;
  int iconY = y + 8;
  const uint16_t* iconPtr = nullptr;
  switch (i) {
    case 0: iconPtr = wifi_icon; break;
    case 1: iconPtr = ir_icon; break;
    case 2: iconPtr = bt_icon; break;
    case 3: iconPtr = tools_icon; break;
    case 4: iconPtr = ghz24_icon; break;
    case 5: iconPtr = settings_icon; break;
    case 6: iconPtr = subghz_icon; break;
    case 7: iconPtr = about_icon; break;
  }
  if (iconPtr) drawRoundedIcon(iconX, iconY, 32, 32, iconPtr, 6);
  tft.setTextColor(textColor, TILE);
  tft.setTextSize(1);
  int16_t textWidth = strlen(items[i]) * 6;
  int textX = x + (TILE_W - textWidth) / 2;
  int textY = y + TILE_H - 15;
  tft.setCursor(textX, textY);
  tft.print(items[i]);
}

void drawUI() {
  tft.fillScreen(BG);
  drawStatusBar();
  for (int i = 0; i < TOTAL; i++) drawTile(i, i == selected);
}

void updateSelection(int oldIndex, int newIndex) {
  drawTile(oldIndex, false);
  drawTile(newIndex, true);
}

// -------- BUTTON HANDLER (one press = one action) --------
bool readButtonOnce(int pin) {
  static bool lastStateUp = false, lastStateDown = false, lastStateLeft = false, lastStateRight = false, lastStateOk = false;
  bool* lastPtr = nullptr;
  if (pin == BTN_UP) lastPtr = &lastStateUp;
  else if (pin == BTN_DOWN) lastPtr = &lastStateDown;
  else if (pin == BTN_LEFT) lastPtr = &lastStateLeft;
  else if (pin == BTN_RIGHT) lastPtr = &lastStateRight;
  else if (pin == BTN_OK) lastPtr = &lastStateOk;
  else return false;
  bool now = (digitalRead(pin) == LOW);
  if (!(*lastPtr) && now) {
    *lastPtr = true;
    return true;
  }
  if (*lastPtr && !now) *lastPtr = false;
  return false;
}

